# ==========================================
# 环境变量配置示例文件
# 复制此文件为 .env 并根据实际情况修改
# ==========================================

# ------------------------------------------
# Docker 镜像仓库配置
# ------------------------------------------
DOCKER_REGISTRY_URL=ghcr.io
DOCKER_REGISTRY_USERNAME=your-github-username
DOCKER_REGISTRY_TOKEN=your-github-token

# ------------------------------------------
# 应用配置
# ------------------------------------------
SPRING_PROFILES_ACTIVE=docker
APP_PORT=7002

# ------------------------------------------
# 数据库配置 (MySQL)
# ------------------------------------------
MYSQL_ROOT_PASSWORD=your-strong-root-password
MYSQL_DATABASE=chongwufuwu
MYSQL_USER=appuser
MYSQL_PASSWORD=your-strong-app-password

# 应用连接数据库配置
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/chongwufuwu?serverTimezone=GMT%2B8&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=appuser
SPRING_DATASOURCE_PASSWORD=your-strong-app-password

# ------------------------------------------
# Redis 配置
# ------------------------------------------
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=your-redis-password

# ------------------------------------------
# JVM 配置
# ------------------------------------------
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC

# ------------------------------------------
# 日志配置
# ------------------------------------------
LOG_LEVEL=INFO
LOG_PATH=/app/logs
